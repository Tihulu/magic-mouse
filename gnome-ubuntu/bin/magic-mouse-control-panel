        ttk.Button(s5, text="Test Browser Forward", command=lambda: self.run_show(BROWSER_NORMAL["swipe_right"])).grid(row=0, column=3, sticky="ew", padx=4, pady=3)

    def _build_settings(self, parent):
        ttk = self.ttk
        parent.columnconfigure(0, weight=1)
        parent.columnconfigure(1, weight=1)

        basics = ttk.LabelFrame(parent, text="Gesture basics", padding=12)
        basics.grid(row=0, column=0, sticky="nsew", padx=(0, 8), pady=(0, 8))
        tuning = ttk.LabelFrame(parent, text="Detection tuning", padding=12)
        tuning.grid(row=0, column=1, sticky="nsew", padx=(8, 0), pady=(0, 8))
        inversion = ttk.LabelFrame(parent, text="Physical axis inversion", padding=12)
        inversion.grid(row=1, column=0, columnspan=2, sticky="ew", pady=(0, 8))

        basics.columnconfigure(1, weight=1)
        tuning.columnconfigure(1, weight=1)
        inversion.columnconfigure(0, weight=1)
        inversion.columnconfigure(1, weight=1)

        self._entry(basics, "device_name_regex", "Device name regex", 0, 42)
        self._entry(basics, "min_fingers", "Minimum fingers", 1)
        self._entry(basics, "log_level", "Log level", 2)
        self._check(basics, "dry_run", "Dry run: detect gestures but do not run commands", 3)

        self._entry(tuning, "threshold_x", "Swipe threshold X", 0)
        self._entry(tuning, "threshold_y", "Swipe threshold Y", 1)
        self._entry(tuning, "diagonal_bias", "Diagonal bias", 2)
        self._entry(tuning, "cooldown_ms", "Cooldown ms", 3)
        self._entry(tuning, "min_duration_ms", "Minimum duration ms", 4)
        self._entry(tuning, "max_duration_ms", "Maximum duration ms", 5)

        self._check(inversion, "invert_x", "Invert physical X axis before action lookup", 0)
        self._check(inversion, "invert_y", "Invert physical Y axis before action lookup", 1)
        ttk.Label(
            inversion,
            text=(
                "Tip: for normal day-to-day direction changes, prefer the direction buttons in Setup Flow. "
                "Physical axis inversion changes how raw device movement is interpreted."
            ),
            wraplength=860,
            justify="left",
        ).grid(row=2, column=0, columnspan=2, sticky="w", pady=(8, 0))

    def _build_actions(self, parent):
        ttk = self.ttk
        parent.columnconfigure(2, weight=1)
        actions = self.config.get("actions", {})
        enabled = self.config.get("enabled", {})
        labels = [
            ("swipe_up", "Swipe up"),
            ("swipe_down", "Swipe down"),
            ("swipe_left", "Swipe left"),
            ("swipe_right", "Swipe right"),
        ]
        self.vars["actions"] = {}
        self.vars["enabled"] = {}
        ttk.Label(parent, text="Enable").grid(row=0, column=1, sticky="w", padx=4)
        ttk.Label(parent, text="Command").grid(row=0, column=2, sticky="w", padx=4)
        for row, (name, label) in enumerate(labels, start=1):
            ttk.Label(parent, text=label).grid(row=row, column=0, sticky="w", pady=5)
            ev = self.tk.BooleanVar(value=bool(enabled.get(name, True)))
            self.vars["enabled"][name] = ev
            ttk.Checkbutton(parent, variable=ev).grid(row=row, column=1, sticky="w")
            cv = self.tk.StringVar(value=str(actions.get(name, DEFAULT_CONFIG["actions"].get(name, ""))))
            self.vars["actions"][name] = cv
            ttk.Entry(parent, textvariable=cv, width=64).grid(row=row, column=2, sticky="ew", pady=5)
            ttk.Button(parent, text="Test", command=lambda n=name: self.test_action(n)).grid(row=row, column=3, padx=6)

        buttons = ttk.Frame(parent)
        buttons.grid(row=6, column=0, columnspan=4, sticky="ew", pady=(12, 0))
        for i in range(4):
            buttons.columnconfigure(i, weight=1)
        ttk.Button(buttons, text="Apply Stable Default", command=self.apply_stable_default).grid(row=0, column=0, sticky="ew", padx=4)
        ttk.Button(buttons, text="Normal Workspace Direction", command=self.normal_workspace_direction).grid(row=0, column=1, sticky="ew", padx=4)
        ttk.Button(buttons, text="Invert Workspace Direction", command=self.invert_workspace_direction).grid(row=0, column=2, sticky="ew", padx=4)
        ttk.Button(buttons, text="Disable Workspace Gestures", command=self.disable_workspace_gestures).grid(row=0, column=3, sticky="ew", padx=4)
        ttk.Button(buttons, text="Normal Browser Direction", command=self.normal_browser_direction).grid(row=1, column=0, sticky="ew", padx=4, pady=(6, 0))
        ttk.Button(buttons, text="Invert Browser Direction", command=self.invert_browser_direction).grid(row=1, column=1, sticky="ew", padx=4, pady=(6, 0))
        ttk.Button(buttons, text="Normal Horizontal Workspace", command=self.normal_horizontal_direction).grid(row=1, column=2, sticky="ew", padx=4, pady=(6, 0))
        ttk.Button(buttons, text="Invert Horizontal Workspace", command=self.invert_horizontal_direction).grid(row=1, column=3, sticky="ew", padx=4, pady=(6, 0))

        tips = (
            "Browser examples use Alt+Left / Alt+Right through wtype. Workspace examples use magic-mouse-ws. "
            "On GNOME Wayland, workspace control is the most reliable path; browser shortcuts depend on synthetic keyboard support."
        )
        ttk.Label(parent, text=tips, wraplength=860).grid(row=7, column=0, columnspan=4, sticky="w", pady=12)

    def _build_service(self, parent):
        ttk = self.ttk
        for i in range(4):
            parent.columnconfigure(i, weight=1)
        cmds = [
            ("Start", "systemctl --user start magic-mouse-gestures.service"),
            ("Stop", "systemctl --user stop magic-mouse-gestures.service"),
            ("Restart", "systemctl --user restart magic-mouse-gestures.service"),
            ("Status", "systemctl --user status magic-mouse-gestures.service --no-pager"),
            ("GNOME Ping", "magic-mouse-ws ping"),
            ("Workspace Status", "magic-mouse-ws status"),
            ("List Devices", "magic-mouse-gesture-daemon --list-devices"),
            ("Recent Logs", "journalctl --user -u magic-mouse-gestures.service -n 100 --no-pager"),
            ("Create Diagnostic Bundle", "magic-mouse-diagnose"),
        ]
        for idx, (label, cmd) in enumerate(cmds):
            ttk.Button(parent, text=label, command=lambda c=cmd: self.run_show(c, timeout=25)).grid(
                row=idx // 4, column=idx % 4, sticky="ew", padx=4, pady=4
            )
        self.output = self.tk.Text(parent, height=24, wrap="word")
        self.output.grid(row=3, column=0, columnspan=4, sticky="nsew", pady=10)
        parent.rowconfigure(3, weight=1)

    def _entry(self, parent, key, label, row, width=32):
        ttk = self.ttk
        v = self.tk.StringVar(value=str(self.config.get(key, DEFAULT_CONFIG.get(key, ""))))
        self.vars[key] = v
        ttk.Label(parent, text=label).grid(row=row, column=0, sticky="w", pady=4)
        ttk.Entry(parent, textvariable=v, width=width).grid(row=row, column=1, sticky="ew", pady=4)
        return v

    def _check(self, parent, key, label, row):
        ttk = self.ttk
        v = self.tk.BooleanVar(value=bool(self.config.get(key, DEFAULT_CONFIG.get(key, False))))
        self.vars[key] = v
        ttk.Checkbutton(parent, text=label, variable=v).grid(row=row, column=0, columnspan=2, sticky="w", pady=4)
        return v

    def _collect(self):
        c = dict(self.config)
        for key in ["device_name_regex", "log_level"]:
            c[key] = self.vars[key].get()
        for key in ["min_fingers", "threshold_x", "threshold_y", "cooldown_ms", "min_duration_ms", "max_duration_ms"]:
            try:
                c[key] = int(float(self.vars[key].get()))
            except ValueError:
                c[key] = DEFAULT_CONFIG[key]
        try:
            c["diagonal_bias"] = float(self.vars["diagonal_bias"].get())
        except ValueError:
            c["diagonal_bias"] = DEFAULT_CONFIG["diagonal_bias"]
        for key in ["invert_x", "invert_y", "dry_run"]:
            c[key] = bool(self.vars[key].get())
        c["actions"] = {k: v.get() for k, v in self.vars["actions"].items()}
        c["enabled"] = {k: bool(v.get()) for k, v in self.vars["enabled"].items()}
        return c

    def _push_config_to_ui(self, config):
        self.config = deep_merge(DEFAULT_CONFIG, config)
        for key, var in self.vars.items():
            if key in {"actions", "enabled"}:
                continue
            if key in self.config and hasattr(var, "set"):
                var.set(self.config[key])
        for name, var in self.vars.get("actions", {}).items():
            var.set(self.config.get("actions", {}).get(name, DEFAULT_CONFIG["actions"].get(name, "")))
        for name, var in self.vars.get("enabled", {}).items():
            var.set(bool(self.config.get("enabled", {}).get(name, True)))
        self.refresh_status()

    def reload(self):
        self._push_config_to_ui(load_config())
        self.run_show(f"echo 'Reloaded: {CONFIG_PATH}'", timeout=3)

    def load_defaults(self):
        self._push_config_to_ui(dict(DEFAULT_CONFIG))
        self.run_show("echo 'Loaded defaults in the panel. Click Apply or Apply & Restart to save.'", timeout=3)

    def save(self):
        self.config = self._collect()
        save_config(self.config)
        self.refresh_status()
        self.run_show(f"echo 'Saved: {CONFIG_PATH}'", timeout=3)

    def save_restart(self):
        self.save()
        self.restart_service()

    def restart_service(self):
        self.run_show("systemctl --user restart magic-mouse-gestures.service && systemctl --user status magic-mouse-gestures.service --no-pager", timeout=25)

    def refresh_status(self):
        rc, out = run_cmd("magic-mouse-ws ping", timeout=4)
        backend = "GNOME workspace backend: ready" if rc == 0 else "GNOME workspace backend: not ready"
        svc_rc, _svc_out = run_cmd("systemctl --user is-active magic-mouse-gestures.service", timeout=4)
        service = "service: active" if svc_rc == 0 else "service: inactive"
        self.status_var.set(f"{backend} / {service}")

    def apply_sensitivity(self, name):
        c = self._collect()
        c.update(SENSITIVITY_PRESETS[name])
        self._push_config_to_ui(c)
        self.run_show(f"echo 'Applied {name} sensitivity. Click Apply & Restart to activate.'", timeout=3)

    def apply_stable_default(self):
        c = self._collect()
        c.update({
            "min_fingers": DEFAULT_CONFIG["min_fingers"],
            "threshold_x": DEFAULT_CONFIG["threshold_x"],
            "threshold_y": DEFAULT_CONFIG["threshold_y"],
            "diagonal_bias": DEFAULT_CONFIG["diagonal_bias"],
            "cooldown_ms": DEFAULT_CONFIG["cooldown_ms"],
            "invert_x": False,
            "invert_y": False,
        })
        c["actions"].update(WORKSPACE_NORMAL)
        c["actions"].update(HORIZONTAL_NORMAL)
        for key in ["swipe_up", "swipe_down", "swipe_left", "swipe_right"]:
            c["enabled"][key] = True
        self._push_config_to_ui(c)
        self.run_show("echo 'Applied stable GNOME workspace defaults. Click Apply & Restart to activate.'", timeout=3)

    def normal_workspace_direction(self):
        c = self._collect()
        c["actions"].update(WORKSPACE_NORMAL)
        c["enabled"]["swipe_up"] = True
        c["enabled"]["swipe_down"] = True
        self._push_config_to_ui(c)
        self.run_show("echo 'Normal workspace direction: swipe up -> previous/up, swipe down -> next/down.'", timeout=3)

    def invert_workspace_direction(self):
        c = self._collect()
        c["actions"].update(WORKSPACE_INVERTED)
        c["enabled"]["swipe_up"] = True
        c["enabled"]["swipe_down"] = True
        self._push_config_to_ui(c)
        self.run_show("echo 'Inverted workspace direction: swipe up -> next/down, swipe down -> previous/up.'", timeout=3)

    def normal_horizontal_direction(self):
        c = self._collect()
        c["actions"].update(HORIZONTAL_NORMAL)
        c["enabled"]["swipe_left"] = True
        c["enabled"]["swipe_right"] = True
        self._push_config_to_ui(c)
        self.run_show("echo 'Normal horizontal workspace direction: left -> left workspace, right -> right workspace.'", timeout=3)

    def invert_horizontal_direction(self):
        c = self._collect()
        c["actions"].update(HORIZONTAL_INVERTED)
        c["enabled"]["swipe_left"] = True
        c["enabled"]["swipe_right"] = True
        self._push_config_to_ui(c)
        self.run_show("echo 'Inverted horizontal workspace direction: left -> right workspace, right -> left workspace.'", timeout=3)

    def normal_browser_direction(self):
        c = self._collect()
        c["actions"].update(BROWSER_NORMAL)
        c["enabled"]["swipe_left"] = True
        c["enabled"]["swipe_right"] = True
        self._push_config_to_ui(c)
        self.run_show("echo 'Normal browser direction: swipe left -> Back, swipe right -> Forward. Click Apply & Restart to activate.'", timeout=3)

    def invert_browser_direction(self):
        c = self._collect()
        c["actions"].update(BROWSER_INVERTED)
        c["enabled"]["swipe_left"] = True
        c["enabled"]["swipe_right"] = True
        self._push_config_to_ui(c)
        self.run_show("echo 'Inverted browser direction: swipe left -> Forward, swipe right -> Back. Click Apply & Restart to activate.'", timeout=3)

    def disable_workspace_gestures(self):
        c = self._collect()
        for key in ["swipe_up", "swipe_down", "swipe_left", "swipe_right"]:
            c["enabled"][key] = False
        self._push_config_to_ui(c)
        self.run_show("echo 'Disabled all workspace/browser gestures. Click Apply & Restart to activate.'", timeout=3)

    def apply_axis_inversion(self, invert_x, invert_y):
        c = self._collect()
        c["invert_x"] = bool(invert_x)
        c["invert_y"] = bool(invert_y)
        self._push_config_to_ui(c)
        self.run_show(
            f"echo 'Physical axis inversion set: invert_x={bool(invert_x)} invert_y={bool(invert_y)}. Click Apply & Restart to activate.'",
            timeout=3,
        )

    def test_action(self, name):
        cmd = self.vars["actions"][name].get()
        self.run_show(cmd)

    def run_show(self, cmd, timeout=12):
        rc, out = run_cmd(cmd, timeout=timeout)
        if not hasattr(self, "output"):
            return
        self.output.delete("1.0", "end")
        self.output.insert("end", f"$ {cmd}\n# exit={rc}\n\n{out}\n")


def launch_gui():
    try:
        import tkinter as tk
    except Exception as exc:
        print("python3-tk is missing. Install it with:", file=sys.stderr)
        print("  sudo apt install -y python3-tk", file=sys.stderr)
        print(f"Error: {exc}", file=sys.stderr)
        return 1
    try:
        root = tk.Tk(className="MagicMouseControlPanel")
        Panel(root)
        root.mainloop()
        return 0
    except tk.TclError as exc:
        print("Could not connect to the graphical display.", file=sys.stderr)
        print(f"DISPLAY={os.environ.get('DISPLAY', 'unset')} WAYLAND_DISPLAY={os.environ.get('WAYLAND_DISPLAY', 'unset')}", file=sys.stderr)
        print("Run the panel from your normal desktop session:", file=sys.stderr)
        print("  magic-mouse-control-panel", file=sys.stderr)
        print("For CLI output:", file=sys.stderr)
        print("  magic-mouse-control-panel --print-config", file=sys.stderr)
        print(f"TclError: {exc}", file=sys.stderr)
        return 1


def main(argv=None):
    p = argparse.ArgumentParser()
    p.add_argument("--print-config", action="store_true")
    p.add_argument("--export-settings", action="store_true")
    args = p.parse_args(argv)
    if args.print_config:
        print(json.dumps(load_config(), indent=2))
        return 0
    if args.export_settings:
        cli_export()
        return 0
    return launch_gui()


if __name__ == "__main__":
    raise SystemExit(main())
