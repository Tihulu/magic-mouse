#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import time
from pathlib import Path

VERSION = "0.2.2"
APP_DIR = Path.home() / ".config" / "magic-mouse"
CONFIG_PATH = APP_DIR / "config.json"

WORKSPACE_NORMAL = {
    "swipe_up": "magic-mouse-ws up",
    "swipe_down": "magic-mouse-ws down",
}
WORKSPACE_INVERTED = {
    "swipe_up": "magic-mouse-ws down",
    "swipe_down": "magic-mouse-ws up",
}
HORIZONTAL_NORMAL = {
    "swipe_left": "magic-mouse-ws left",
    "swipe_right": "magic-mouse-ws right",
}
HORIZONTAL_INVERTED = {
    "swipe_left": "magic-mouse-ws right",
    "swipe_right": "magic-mouse-ws left",
}
BROWSER_NORMAL = {
    "swipe_left": "wtype -M alt -P left -p left -m alt",
    "swipe_right": "wtype -M alt -P right -p right -m alt",
}
BROWSER_INVERTED = {
    "swipe_left": "wtype -M alt -P right -p right -m alt",
    "swipe_right": "wtype -M alt -P left -p left -m alt",
}

SENSITIVITY_PRESETS = {
    "Sensitive": {
        "threshold_x": 520,
        "threshold_y": 460,
        "cooldown_ms": 420,
        "diagonal_bias": 1.10,
    },
    "Default": {
        "threshold_x": 700,
        "threshold_y": 600,
        "cooldown_ms": 550,
        "diagonal_bias": 1.25,
    },
    "Conservative": {
        "threshold_x": 900,
        "threshold_y": 780,
        "cooldown_ms": 650,
        "diagonal_bias": 1.35,
    },
}

DEFAULT_CONFIG = {
    "backend": "evdev",
    "device_name_regex": "Magic Mouse|Magic Trackpad",
    "min_fingers": 2,
    "threshold_x": 700,
    "threshold_y": 600,
    "diagonal_bias": 1.25,
    "min_duration_ms": 60,
    "max_duration_ms": 1500,
    "cooldown_ms": 550,
    "invert_x": False,
    "invert_y": False,
    "dry_run": False,
    "log_level": "info",
    "actions": {
        **WORKSPACE_NORMAL,
        **HORIZONTAL_NORMAL,
    },
    "enabled": {
        "swipe_up": True,
        "swipe_down": True,
        "swipe_left": True,
        "swipe_right": True,
    },
}


def deep_merge(base, override):
    out = dict(base)
    for key, value in override.items():
        if isinstance(value, dict) and isinstance(out.get(key), dict):
            out[key] = deep_merge(out[key], value)
        else:
            out[key] = value
    return out


def load_config():
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    if not CONFIG_PATH.exists():
        save_config(DEFAULT_CONFIG)
        return dict(DEFAULT_CONFIG)
    try:
        return deep_merge(DEFAULT_CONFIG, json.loads(CONFIG_PATH.read_text(encoding="utf-8")))
    except Exception as exc:
        print(f"Could not read config: {CONFIG_PATH}: {exc}", file=sys.stderr)
        return dict(DEFAULT_CONFIG)


def save_config(config):
    CONFIG_PATH.parent.mkdir(parents=True, exist_ok=True)
    CONFIG_PATH.write_text(json.dumps(config, indent=2) + "\n", encoding="utf-8")


def run_cmd(cmd, timeout=12):
    env = os.environ.copy()
    env["PATH"] = str(Path.home() / ".local" / "bin") + os.pathsep + env.get("PATH", "")
    try:
        p = subprocess.run(cmd, shell=True, text=True, capture_output=True, timeout=timeout, env=env)
        out = (p.stdout or "") + (p.stderr or "")
        return p.returncode, out.strip()
    except subprocess.TimeoutExpired:
        return 124, "timeout"
    except Exception as exc:
        return 1, str(exc)


def cli_export():
    ts = time.strftime("%Y%m%d-%H%M%S")
    out = Path("/tmp") / f"magic-mouse-settings-{ts}.json"
    out.write_text(json.dumps(load_config(), indent=2) + "\n", encoding="utf-8")
    print(out)


class ScrollableFrame:
    def __init__(self, parent, ttk, tk, padding=12):
        self.tk = tk
        self.ttk = ttk
        self.frame = ttk.Frame(parent)
        self.canvas = tk.Canvas(self.frame, borderwidth=0, highlightthickness=0)
        self.vbar = ttk.Scrollbar(self.frame, orient="vertical", command=self.canvas.yview)
        self.canvas.configure(yscrollcommand=self.vbar.set)
        self.inner = ttk.Frame(self.canvas, padding=padding)
        self.window_id = self.canvas.create_window((0, 0), window=self.inner, anchor="nw")

        self.canvas.grid(row=0, column=0, sticky="nsew")
        self.vbar.grid(row=0, column=1, sticky="ns")
        self.frame.rowconfigure(0, weight=1)
        self.frame.columnconfigure(0, weight=1)

        self.inner.bind("<Configure>", self._on_inner_configure)
        self.canvas.bind("<Configure>", self._on_canvas_configure)
        self.canvas.bind("<Enter>", self._bind_mousewheel)
        self.canvas.bind("<Leave>", self._unbind_mousewheel)

    def _on_inner_configure(self, _event=None):
        self.canvas.configure(scrollregion=self.canvas.bbox("all"))

    def _on_canvas_configure(self, event):
        self.canvas.itemconfigure(self.window_id, width=event.width)

    def _bind_mousewheel(self, _event=None):
        self.canvas.bind_all("<MouseWheel>", self._on_mousewheel)
        self.canvas.bind_all("<Button-4>", self._on_button4)
        self.canvas.bind_all("<Button-5>", self._on_button5)

    def _unbind_mousewheel(self, _event=None):
        self.canvas.unbind_all("<MouseWheel>")
        self.canvas.unbind_all("<Button-4>")
        self.canvas.unbind_all("<Button-5>")

    def _on_mousewheel(self, event):
        step = int(-1 * (event.delta / 120)) if event.delta else 0
        if step:
            self.canvas.yview_scroll(step, "units")
        return "break"

    def _on_button4(self, _event):
        self.canvas.yview_scroll(-3, "units")
        return "break"

    def _on_button5(self, _event):
        self.canvas.yview_scroll(3, "units")
        return "break"


class Panel:
    def __init__(self, root):
        import tkinter as tk
        from tkinter import ttk
        self.tk = tk
        self.ttk = ttk
        self.root = root
        self.config = load_config()
        self.vars = {}
        self.status_var = tk.StringVar()
        self.session_var = tk.StringVar(
            value=f"Session: {os.getenv('XDG_SESSION_TYPE', 'unknown')} / {os.getenv('XDG_CURRENT_DESKTOP', 'unknown')}"
        )
        self.config_path_var = tk.StringVar(value=str(CONFIG_PATH))

        root.title(f"Magic Mouse Control Panel v{VERSION}")
        root.geometry("980x800")
        root.minsize(760, 560)
        self._build_ui()
        self.refresh_status()

    def _build_ui(self):
        ttk = self.ttk
        root = self.root
        root.columnconfigure(0, weight=1)
        root.rowconfigure(1, weight=1)

        header = ttk.Frame(root, padding=12)
        header.grid(row=0, column=0, sticky="ew")
        header.columnconfigure(0, weight=1)
        ttk.Label(header, text=f"Magic Mouse Control Panel v{VERSION}", font=("Sans", 16, "bold")).grid(row=0, column=0, sticky="w")
        ttk.Label(header, text="GNOME / Ubuntu workspace gestures", font=("Sans", 10)).grid(row=1, column=0, sticky="w", pady=(2, 0))
        ttk.Label(header, textvariable=self.session_var).grid(row=2, column=0, sticky="w", pady=(4, 0))
        ttk.Label(header, textvariable=self.status_var, foreground="#0a6").grid(row=3, column=0, sticky="w", pady=(4, 0))
        ttk.Label(header, textvariable=self.config_path_var).grid(row=4, column=0, sticky="w", pady=(2, 0))

        notebook = ttk.Notebook(root)
        notebook.grid(row=1, column=0, sticky="nsew", padx=12, pady=(0, 12))

        setup_shell = ScrollableFrame(notebook, ttk, self.tk, padding=12)
        settings_shell = ScrollableFrame(notebook, ttk, self.tk, padding=12)
        actions_shell = ScrollableFrame(notebook, ttk, self.tk, padding=12)
        service = ttk.Frame(notebook, padding=12)

        notebook.add(setup_shell.frame, text="Setup Flow")
        notebook.add(settings_shell.frame, text="Advanced Settings")
        notebook.add(actions_shell.frame, text="Gesture Commands")
        notebook.add(service, text="Tools / Diagnostics")

        self._build_setup(setup_shell.inner)
        self._build_settings(settings_shell.inner)
        self._build_actions(actions_shell.inner)
        self._build_service(service)

        footer = ttk.Frame(root, padding=(12, 0, 12, 12))
        footer.grid(row=2, column=0, sticky="ew")
        for i in range(5):
            footer.columnconfigure(i, weight=1)
        ttk.Button(footer, text="Reload", command=self.reload).grid(row=0, column=0, padx=4, sticky="ew")
        ttk.Button(footer, text="Defaults", command=self.load_defaults).grid(row=0, column=1, padx=4, sticky="ew")
        ttk.Button(footer, text="Apply", command=self.save).grid(row=0, column=2, padx=4, sticky="ew")
        ttk.Button(footer, text="Apply & Restart", command=self.save_restart).grid(row=0, column=3, padx=4, sticky="ew")
        ttk.Button(footer, text="Close", command=root.destroy).grid(row=0, column=4, padx=4, sticky="ew")

    def _build_setup(self, parent):
        ttk = self.ttk
        parent.columnconfigure(0, weight=1)

        intro = (
            "Recommended order: 1) Status  2) Restart gesture service  3) Sensitivity preset  "
            "4) Direction buttons  5) Test workspace/browser commands"
        )
        ttk.Label(parent, text=intro, wraplength=900, justify="left").grid(row=0, column=0, sticky="w", pady=(0, 10))

        s1 = ttk.LabelFrame(parent, text="Step 1 — Status", padding=10)
        s1.grid(row=1, column=0, sticky="ew", pady=6)
        for i in range(4):
            s1.columnconfigure(i, weight=1)
        ttk.Button(s1, text="Refresh Status", command=self.refresh_status).grid(row=0, column=0, sticky="ew", padx=4, pady=3)
        ttk.Button(s1, text="GNOME Ping", command=lambda: self.run_show("magic-mouse-ws ping")).grid(row=0, column=1, sticky="ew", padx=4, pady=3)
        ttk.Button(s1, text="Workspace Status", command=lambda: self.run_show("magic-mouse-ws status")).grid(row=0, column=2, sticky="ew", padx=4, pady=3)
        ttk.Button(s1, text="List Devices", command=lambda: self.run_show("magic-mouse-gesture-daemon --list-devices", timeout=20)).grid(row=0, column=3, sticky="ew", padx=4, pady=3)

        s2 = ttk.LabelFrame(parent, text="Step 2 — Service", padding=10)
        s2.grid(row=2, column=0, sticky="ew", pady=6)
        for i in range(3):
            s2.columnconfigure(i, weight=1)
        ttk.Button(s2, text="Restart Gesture Service", command=self.restart_service).grid(row=0, column=0, sticky="ew", padx=4, pady=3)
        ttk.Button(s2, text="Show Service Status", command=lambda: self.run_show("systemctl --user status magic-mouse-gestures.service --no-pager", timeout=20)).grid(row=0, column=1, sticky="ew", padx=4, pady=3)
        ttk.Button(s2, text="Show Recent Logs", command=lambda: self.run_show("journalctl --user -u magic-mouse-gestures.service -n 100 --no-pager", timeout=20)).grid(row=0, column=2, sticky="ew", padx=4, pady=3)

        s3 = ttk.LabelFrame(parent, text="Step 3 — Sensitivity presets", padding=10)
        s3.grid(row=3, column=0, sticky="ew", pady=6)
        for i in range(3):
            s3.columnconfigure(i, weight=1)
        ttk.Button(s3, text="Sensitive", command=lambda: self.apply_sensitivity("Sensitive")).grid(row=0, column=0, sticky="ew", padx=4, pady=3)
        ttk.Button(s3, text="Default", command=lambda: self.apply_sensitivity("Default")).grid(row=0, column=1, sticky="ew", padx=4, pady=3)
        ttk.Button(s3, text="Conservative", command=lambda: self.apply_sensitivity("Conservative")).grid(row=0, column=2, sticky="ew", padx=4, pady=3)

        s4 = ttk.LabelFrame(parent, text="Step 4 — Direction / inversion", padding=10)
        s4.grid(row=4, column=0, sticky="ew", pady=6)
        for i in range(4):
            s4.columnconfigure(i, weight=1)
        ttk.Label(
            s4,
            text=(
                "Workspace direction controls GNOME workspaces. Browser direction sends Alt+Left/Alt+Right. "
                "Physical axis inversion is only for cases where the raw detected swipe itself is reversed."
            ),
            wraplength=900,
            justify="left",
        ).grid(row=0, column=0, columnspan=4, sticky="w", pady=(0, 8))
        ttk.Button(s4, text="Apply Stable Default", command=self.apply_stable_default).grid(row=1, column=0, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Normal Workspace Direction", command=self.normal_workspace_direction).grid(row=1, column=1, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Invert Workspace Direction", command=self.invert_workspace_direction).grid(row=1, column=2, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Disable Workspace Gestures", command=self.disable_workspace_gestures).grid(row=1, column=3, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Normal Browser Direction", command=self.normal_browser_direction).grid(row=2, column=0, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Invert Browser Direction", command=self.invert_browser_direction).grid(row=2, column=1, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Normal Horizontal Workspace", command=self.normal_horizontal_direction).grid(row=2, column=2, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Invert Horizontal Workspace", command=self.invert_horizontal_direction).grid(row=2, column=3, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Normal Physical Axes", command=lambda: self.apply_axis_inversion(False, False)).grid(row=3, column=0, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Invert X Axis", command=lambda: self.apply_axis_inversion(True, self.vars["invert_y"].get())).grid(row=3, column=1, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Invert Y Axis", command=lambda: self.apply_axis_inversion(self.vars["invert_x"].get(), True)).grid(row=3, column=2, sticky="ew", padx=4, pady=3)
        ttk.Button(s4, text="Invert Both Axes", command=lambda: self.apply_axis_inversion(True, True)).grid(row=3, column=3, sticky="ew", padx=4, pady=3)

