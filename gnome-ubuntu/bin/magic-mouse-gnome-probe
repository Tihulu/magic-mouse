#!/usr/bin/env bash
set -euo pipefail
has() { command -v "$1" >/dev/null 2>&1; }

echo "== Session =="
echo "USER=${USER:-unset}"
echo "XDG_SESSION_TYPE=${XDG_SESSION_TYPE:-unset}"
echo "XDG_CURRENT_DESKTOP=${XDG_CURRENT_DESKTOP:-unset}"
echo "DESKTOP_SESSION=${DESKTOP_SESSION:-unset}"
echo "DISPLAY=${DISPLAY:-unset}"
echo "WAYLAND_DISPLAY=${WAYLAND_DISPLAY:-unset}"
if has gnome-shell; then gnome-shell --version || true; else echo "gnome-shell missing"; fi

echo
echo "== Binaries =="
for b in gdbus gnome-extensions python3 magic-mouse-ws magic-mouse-gesture-daemon magic-mouse-control-panel xdotool; do
  if has "$b"; then echo "$b: $(command -v "$b")"; else echo "missing: $b"; fi
done

echo
echo "== Python deps =="
python3 - <<'PY' 2>&1 || true
mods = ['evdev', 'tkinter']
for m in mods:
    try:
        __import__(m)
        print(f'ok: {m}')
    except Exception as e:
        print(f'missing: {m}: {e}')
PY

echo
echo "== Extension =="
if has gnome-extensions; then
  gnome-extensions info magic-mouse-workspaces@horseman.local 2>/dev/null || echo "extension not installed/enabled"
else
  echo "gnome-extensions missing"
fi

echo
echo "== Backend ping =="
if has magic-mouse-ws; then magic-mouse-ws ping || true; else echo "magic-mouse-ws not on PATH"; fi

echo
echo "== Gesture service =="
systemctl --user --no-pager status magic-mouse-gestures.service 2>&1 | sed -n '1,40p' || true

echo
echo "== Devices =="
if has magic-mouse-gesture-daemon; then magic-mouse-gesture-daemon --list-devices || true; else echo "daemon missing"; fi

echo
echo "== GNOME Shell Eval smoke test =="
if has gdbus; then
  gdbus call --session --dest org.gnome.Shell --object-path /org/gnome/Shell --method org.gnome.Shell.Eval "true" 2>&1 || true
else
  echo "gdbus missing"
fi
