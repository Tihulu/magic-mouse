def run(cmd,timeout=None,env=None): return subprocess.run(cmd,text=True,capture_output=True,timeout=timeout,env=env)
def q(v): return '"'+str(v).replace('"','\\"')+'"'
def read_profile():
 d={}
 if not PROFILE.exists(): return d
 for line in PROFILE.read_text().splitlines():
  line=line.strip()
  if not line or line.startswith('#') or '=' not in line: continue
  k,v=line.split('=',1); v=v.strip()
  if len(v)>1 and v[0]==v[-1] and v[0] in "'\"": v=v[1:-1]
  d[k.strip()]=v
 return d
def backup():
 if not PROFILE.exists(): return
 b=HOME/"Documents/magicmouse-backups"; b.mkdir(parents=True,exist_ok=True)
 shutil.copy2(PROFILE,b/f"profile.env.{int(time.time())}.bak")
def write_profile(d):
 PROFILE.parent.mkdir(parents=True,exist_ok=True)
 order=["MIN_TOUCHES","MAX_FINGERS","SWIPE_THRESHOLD_X","SWIPE_THRESHOLD_Y","SWIPE_COOLDOWN_MS","AXIS_LOCK_RATIO","INVERT_X_1F","INVERT_Y_1F","INVERT_X_2F","INVERT_Y_2F","GESTURE_LEFT","GESTURE_RIGHT","GESTURE_UP","GESTURE_DOWN"]
 keys=order+sorted(k for k in d if k not in order)
 lines=["# Magic Mouse COSMIC profile",f"# Generated by magic-mouse-control-panel v{VERSION}"]
 for k in keys:
  if k in d: lines.append(f"{k}={q(d[k])}")
 PROFILE.write_text('\n'.join(lines)+'\n')

