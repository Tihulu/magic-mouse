 def hid_status(self):
  r=run(['journalctl','--user','-u','magic-mouse-gestures','-n','40','-l','--no-pager'],10); txt=(r.stdout or '')+(r.stderr or '')
  if 'cannot read it' in txt: return 'Needs repair'
  if '[hidraw] opened' in txt or 'profile=cosmic' in txt: return 'OK'
  return 'Unknown'
 def scroll_status(self):
  if not SCROLL.exists(): return 'helper missing'
  r=run([str(SCROLL),'status'],10); txt=(r.stdout or '')+(r.stderr or '')
  if 'natural_scroll=true' in txt or 'natural-scroll=true' in txt: return 'Natural / Mac-style'
  if 'natural_scroll=false' in txt or 'natural-scroll=false' in txt: return 'Traditional'
  return 'Unset / unknown'
 def refresh_status(self):
  if self.status_running: return
  self.status_running=True
  def worker():
   try:
    state=(run(['systemctl','--user','is-active','magic-mouse-gestures'],10).stdout or 'unknown').strip() or 'unknown'; d=read_profile(); mapping=self.map_status(d); hid=self.hid_status(); scroll=self.scroll_status(); info=[f'Service: {state}',f'Mapping: {mapping}',f'HID: {hid}',f'Scroll: {scroll}','']
    info += ['== Profile ==',PROFILE.read_text()] if PROFILE.exists() else [f'Profile missing: {PROFILE}']
    def apply():
     self.status_running=False; self.mode.set('Mode: '+mapping); self.status.set(f'Service: {state} | HID: {hid} | Scroll: {scroll}'); self.info.configure(state='normal'); self.info.delete('1.0','end'); self.info.insert('1.0','\n'.join(info)); self.info.configure(state='disabled')
    self.root.after(0,apply)
   except Exception as e: self.root.after(0,lambda:(setattr(self,'status_running',False),self.status.set(f'Status failed: {e}')))
  threading.Thread(target=worker,daemon=True).start()

