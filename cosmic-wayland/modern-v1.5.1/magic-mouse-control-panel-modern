 def output(self,title,text):
  w=tk.Toplevel(self.root); w.title(title); w.geometry('920x620'); w.configure(bg=C['bg']); t=ScrolledText(w,wrap='word',bg='#07101f',fg=C['text'],insertbackground=C['text'],relief='flat'); t.pack(fill='both',expand=True,padx=12,pady=12); t.insert('1.0',text); t.configure(state='disabled')
 def bg(self,title,worker,success=None,err=None,show=True,done=None):
  if self.busy: messagebox.showinfo('Busy','Another action is already running.'); return
  self.busy=True; self.status.set(f"Working: {title}...")
  def progress(_p,text): self.root.after(0,lambda:self.status.set(text))
  def task():
   try:
    res=worker(progress)
    def ok():
     self.busy=False
     if done: done(res)
     self.refresh_status()
     if show and success: messagebox.showinfo(title,success)
    self.root.after(0,ok)
   except Exception as e:
    self.root.after(0,lambda:(setattr(self,'busy',False),self.status.set(f"Failed: {title}"),self.refresh_status(),messagebox.showerror(err or title,str(e))))
  threading.Thread(target=task,daemon=True).start()
 def restart_sync(self): subprocess.run(['systemctl','--user','daemon-reload'],text=True,capture_output=True); return run(['systemctl','--user','restart','magic-mouse-gestures'],30)
 def update(self,vals,progress):
  progress(15,'Reading profile...'); d=read_profile(); d.update(vals); progress(35,'Backing up profile...'); backup(); progress(55,'Writing profile...'); write_profile(d); progress(80,'Restarting service...'); r=self.restart_sync()
  if r.returncode: raise RuntimeError(r.stderr or r.stdout or 'Service restart failed')
  return d
 def map_status(self,d):
  up=d.get('GESTURE_UP',''); down=d.get('GESTURE_DOWN',''); left=d.get('GESTURE_LEFT',''); right=d.get('GESTURE_RIGHT','')
  ws='Workspace: Normal' if up.endswith(' up') and down.endswith(' down') else 'Workspace: Inverted' if up.endswith(' down') and down.endswith(' up') else 'Workspace: Custom'
  br='Browser: Normal' if 'left' in left and 'right' in right else 'Browser: Inverted' if 'right' in left and 'left' in right else 'Browser: Custom'
  return f'{ws} · {br}'
 def preview(self,vals): d=read_profile(); d.update(vals); self.mode.set('Mode: '+self.map_status(d))
 def apply_default(self): self.apply_map(DEFAULT,'Stable defaults applied.')
 def apply_map(self,vals,msg): self.preview(vals); self.bg('Apply mapping',lambda p:self.update(vals,p),msg,'Gesture mapping failed')
 def apply_named(self,name): self.preset.set(name); self.apply_sens()
 def custom_vals(self):
  try: x=int(self.cx.get()); y=int(self.cy.get()); c=int(self.cc.get()); a=float(self.ca.get())
  except ValueError: raise ValueError('Custom sensitivity values must be numeric.')
  if x<120 or y<120 or c<100: raise ValueError('Custom X/Y thresholds and cooldown are too low.')
  if a<1.0 or a>3.0: raise ValueError('Axis lock should be between 1.0 and 3.0.')
  return {"SWIPE_THRESHOLD_X":str(x),"SWIPE_THRESHOLD_Y":str(y),"SWIPE_COOLDOWN_MS":str(c),"AXIS_LOCK_RATIO":f"{a:.2f}"}
 def apply_custom(self):
  try: vals=self.custom_vals()
  except ValueError as e: messagebox.showerror('Custom sensitivity',str(e)); return
  self.apply_map(vals,'Custom sensitivity applied.')
 def apply_sens(self):
  name=self.preset.get()
  if name=='Custom': self.apply_custom(); return
  vals=PRESETS.get(name)
  if not vals: messagebox.showerror('Sensitivity','Choose a valid preset.'); return
  self.apply_map(vals,f"Applied the '{name}' preset.")
