#!/usr/bin/env python3
import os
import shutil
import subprocess
import threading
import time
from pathlib import Path
import tkinter as tk
from tkinter import ttk, messagebox, simpledialog
from tkinter.scrolledtext import ScrolledText

VERSION = "1.4.8"
HOME = Path.home()
PROFILE = HOME / ".config/magic-mouse-gestures/profile.env"
RUNTIME_DIR = HOME / ".local/share/magic-mouse-cosmic-workspaces"
VERIFY = RUNTIME_DIR / "verify.sh"
REPAIR = RUNTIME_DIR / "repair-permissions.sh"
CLI_PANEL = HOME / ".local/bin/magic-mouse-control-panel-cli"
COSMIC_WS = HOME / ".local/bin/cosmic-ws"
SCROLL_HELPER = HOME / ".local/bin/magic-mouse-scroll-direction"

DEFAULT_MAPPING = {
    "MIN_TOUCHES": "2",
    "MAX_FINGERS": "5",
    "SWIPE_THRESHOLD_X": "360",
    "SWIPE_THRESHOLD_Y": "420",
    "SWIPE_COOLDOWN_MS": "450",
    "AXIS_LOCK_RATIO": "1.15",
    "INVERT_X_1F": "0",
    "INVERT_Y_1F": "0",
    "INVERT_X_2F": "0",
    "INVERT_Y_2F": "0",
    "GESTURE_LEFT": "wtype -M alt -P left -p left -m alt",
    "GESTURE_RIGHT": "wtype -M alt -P right -p right -m alt",
    "GESTURE_UP": str(HOME / ".local/bin/cosmic-ws") + " up",
    "GESTURE_DOWN": str(HOME / ".local/bin/cosmic-ws") + " down",
}

WORKSPACE_NORMAL = {
    "GESTURE_UP": str(HOME / ".local/bin/cosmic-ws") + " up",
    "GESTURE_DOWN": str(HOME / ".local/bin/cosmic-ws") + " down",
}
WORKSPACE_INVERTED = {
    "GESTURE_UP": str(HOME / ".local/bin/cosmic-ws") + " down",
    "GESTURE_DOWN": str(HOME / ".local/bin/cosmic-ws") + " up",
}
BROWSER_NORMAL = {
    "GESTURE_LEFT": "wtype -M alt -P left -p left -m alt",
    "GESTURE_RIGHT": "wtype -M alt -P right -p right -m alt",
}
BROWSER_INVERTED = {
    "GESTURE_LEFT": "wtype -M alt -P right -p right -m alt",
    "GESTURE_RIGHT": "wtype -M alt -P left -p left -m alt",
}
SENSITIVITY_PRESETS = {
    "Default": {"SWIPE_THRESHOLD_X": "360", "SWIPE_THRESHOLD_Y": "420", "SWIPE_COOLDOWN_MS": "450", "AXIS_LOCK_RATIO": "1.15"},
    "Sensitive": {"SWIPE_THRESHOLD_X": "280", "SWIPE_THRESHOLD_Y": "340", "SWIPE_COOLDOWN_MS": "380", "AXIS_LOCK_RATIO": "1.10"},
    "Relaxed": {"SWIPE_THRESHOLD_X": "460", "SWIPE_THRESHOLD_Y": "520", "SWIPE_COOLDOWN_MS": "550", "AXIS_LOCK_RATIO": "1.20"},
}


def run_command(cmd, timeout=None):
    return subprocess.run(cmd, text=True, capture_output=True, timeout=timeout)


def shell_quote(value):
    return '"' + str(value).replace('"', '\\"') + '"'


def read_profile():
    data = {}
    if not PROFILE.exists():
        return data
    for line in PROFILE.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#") or "=" not in line:
            continue
        key, value = line.split("=", 1)
        value = value.strip()
        if len(value) >= 2 and value[0] == value[-1] and value[0] in "'\"":
            value = value[1:-1]
        data[key.strip()] = value
    return data


def backup_profile():
    if not PROFILE.exists():
        return None
    backup_dir = HOME / "Documents/magicmouse-backups"
    backup_dir.mkdir(parents=True, exist_ok=True)
    target = backup_dir / f"profile.env.{int(time.time())}.bak"
    shutil.copy2(PROFILE, target)
    return target


def write_profile(data):
    PROFILE.parent.mkdir(parents=True, exist_ok=True)
    ordered = [
        "MIN_TOUCHES", "MAX_FINGERS", "SWIPE_THRESHOLD_X", "SWIPE_THRESHOLD_Y", "SWIPE_COOLDOWN_MS", "AXIS_LOCK_RATIO",
        "INVERT_X_1F", "INVERT_Y_1F", "INVERT_X_2F", "INVERT_Y_2F",
        "GESTURE_LEFT", "GESTURE_RIGHT", "GESTURE_UP", "GESTURE_DOWN",
    ]
    keys = ordered + sorted(k for k in data if k not in ordered)
    lines = ["# Magic Mouse COSMIC profile", "# Generated by magic-mouse-control-panel v" + VERSION]
    for key in keys:
        if key in data:
            lines.append(f"{key}={shell_quote(data[key])}")
    PROFILE.write_text("\n".join(lines) + "\n")


def show_output_window(title, text):
    win = tk.Toplevel()
    win.title(title)
    win.geometry("980x720")
    txt = ScrolledText(win, wrap="word")
    txt.pack(fill="both", expand=True)
    txt.insert("1.0", text)
    txt.configure(state="disabled")


class App:
    def __init__(self, root):
        self.root = root
        self.root.title(f"Magic Mouse Control Panel v{VERSION}")
        self.root.geometry("920x680")
        self.root.minsize(760, 520)
        self.status_var = tk.StringVar(value="Loading...")
        self.session_var = tk.StringVar(value=f"Session: {os.getenv('XDG_SESSION_TYPE', 'unknown')} / {os.getenv('XDG_CURRENT_DESKTOP', 'unknown')}")
        self.progress_value = tk.IntVar(value=0)
        self.progress_text = tk.StringVar(value="Idle")
        self.progress_win = None
        self.busy = False
        self.sensitivity_var = tk.StringVar(value="Default")
        self._build_ui()
        self.root.after(150, self.refresh_status_async)

    def _build_ui(self):
        self.root.columnconfigure(0, weight=1)
        self.root.rowconfigure(1, weight=1)
        header = ttk.Frame(self.root, padding=12)
        header.grid(row=0, column=0, sticky="ew")
        header.columnconfigure(0, weight=1)
        ttk.Label(header, text=f"Magic Mouse Control Panel v{VERSION}", font=("Sans", 16, "bold")).grid(row=0, column=0, sticky="w")
        ttk.Label(header, textvariable=self.session_var).grid(row=1, column=0, sticky="w", pady=(4, 0))
        ttk.Label(header, textvariable=self.status_var).grid(row=2, column=0, sticky="w", pady=(4, 0))

        notebook = ttk.Notebook(self.root)
        notebook.grid(row=1, column=0, sticky="nsew", padx=12, pady=(0, 12))
        setup = ttk.Frame(notebook, padding=12)
        tools = ttk.Frame(notebook, padding=12)
        info = ttk.Frame(notebook, padding=12)
        notebook.add(setup, text="Setup")
        notebook.add(tools, text="Tools")
        notebook.add(info, text="Info")
        for frame in (setup, tools):
            for col in range(3):
                frame.columnconfigure(col, weight=1)

        ttk.Label(setup, text="Gesture mapping", font=("Sans", 12, "bold")).grid(row=0, column=0, sticky="w", columnspan=3, pady=(0, 8))
        ttk.Button(setup, text="Apply Stable Defaults", command=self.apply_stable_defaults).grid(row=1, column=0, padx=4, pady=4, sticky="ew")
        ttk.Button(setup, text="Normal Workspace Direction", command=lambda: self.apply_mapping(WORKSPACE_NORMAL, "Workspace direction set to normal.")) .grid(row=1, column=1, padx=4, pady=4, sticky="ew")
        ttk.Button(setup, text="Invert Workspace Direction", command=lambda: self.apply_mapping(WORKSPACE_INVERTED, "Workspace direction inverted.")) .grid(row=1, column=2, padx=4, pady=4, sticky="ew")
        ttk.Button(setup, text="Normal Browser Direction", command=lambda: self.apply_mapping(BROWSER_NORMAL, "Browser direction set to normal.")) .grid(row=2, column=0, padx=4, pady=4, sticky="ew")
        ttk.Button(setup, text="Invert Browser Direction", command=lambda: self.apply_mapping(BROWSER_INVERTED, "Browser direction inverted.")) .grid(row=2, column=1, padx=4, pady=4, sticky="ew")
        ttk.Button(setup, text="Restart Service", command=self.restart_service).grid(row=2, column=2, padx=4, pady=4, sticky="ew")

        ttk.Separator(setup).grid(row=3, column=0, columnspan=3, sticky="ew", pady=12)
        ttk.Label(setup, text="Scroll direction", font=("Sans", 12, "bold")).grid(row=4, column=0, sticky="w", columnspan=3, pady=(0, 8))
        ttk.Button(setup, text="Natural / Mac-style Scroll", command=lambda: self.apply_scroll("natural", False)).grid(row=5, column=0, padx=4, pady=4, sticky="ew")
        ttk.Button(setup, text="Traditional Scroll", command=lambda: self.apply_scroll("traditional", False)).grid(row=5, column=1, padx=4, pady=4, sticky="ew")
        ttk.Button(setup, text="Show Scroll Status", command=lambda: self.apply_scroll("status", True)).grid(row=5, column=2, padx=4, pady=4, sticky="ew")

        ttk.Separator(setup).grid(row=6, column=0, columnspan=3, sticky="ew", pady=12)
        ttk.Label(setup, text="Sensitivity preset", font=("Sans", 12, "bold")).grid(row=7, column=0, sticky="w", columnspan=3, pady=(0, 8))
        ttk.OptionMenu(setup, self.sensitivity_var, "Default", *SENSITIVITY_PRESETS.keys()).grid(row=8, column=0, padx=4, pady=4, sticky="ew")
        ttk.Button(setup, text="Apply Sensitivity Preset", command=self.apply_sensitivity).grid(row=8, column=1, padx=4, pady=4, sticky="ew")
        ttk.Button(setup, text="Refresh Status", command=self.refresh_status_async).grid(row=8, column=2, padx=4, pady=4, sticky="ew")

        ttk.Label(tools, text="Maintenance", font=("Sans", 12, "bold")).grid(row=0, column=0, sticky="w", columnspan=3, pady=(0, 8))
        ttk.Button(tools, text="Repair HID Permissions", command=self.repair_permissions).grid(row=1, column=0, padx=4, pady=4, sticky="ew")
        ttk.Button(tools, text="Verify Setup", command=self.verify_setup).grid(row=1, column=1, padx=4, pady=4, sticky="ew")
        ttk.Button(tools, text="Open CLI Panel", command=self.open_cli_panel).grid(row=1, column=2, padx=4, pady=4, sticky="ew")
        ttk.Button(tools, text="Test Workspace Up", command=lambda: self.test_workspace("up")).grid(row=2, column=0, padx=4, pady=4, sticky="ew")
        ttk.Button(tools, text="Test Workspace Down", command=lambda: self.test_workspace("down")).grid(row=2, column=1, padx=4, pady=4, sticky="ew")

        self.info_text = ScrolledText(info, wrap="word")
        self.info_text.pack(fill="both", expand=True)

    def _place_progress(self, win, width=380, height=120):
        try:
            sw = self.root.winfo_screenwidth()
            sh = self.root.winfo_screenheight()
            win.geometry(f"{width}x{height}+{max(0, sw - width - 24)}+{max(0, sh - height - 64)}")
        except Exception:
            win.geometry(f"{width}x{height}")

    def progress_start(self, title):
        try:
            if self.progress_win is not None and self.progress_win.winfo_exists():
                self.progress_win.destroy()
        except Exception:
            pass
        self.progress_value.set(0)
        self.progress_text.set("Starting...")
        win = tk.Toplevel(self.root)
        win.title(title)
        win.resizable(False, False)
        win.attributes("-topmost", True)
        frame = ttk.Frame(win, padding=12)
        frame.pack(fill="both", expand=True)
        ttk.Label(frame, text=title, font=("Sans", 10, "bold")).pack(anchor="w")
        ttk.Label(frame, textvariable=self.progress_text, wraplength=340).pack(anchor="w", pady=(6, 8))
        ttk.Progressbar(frame, maximum=100, variable=self.progress_value, length=340).pack(fill="x")
        self.progress_win = win
        self._place_progress(win, width=380, height=120)

    def progress_update(self, percent, text):
        self.root.after(0, lambda: (self.progress_value.set(max(0, min(100, int(percent)))), self.progress_text.set(text)))

    def progress_finish(self, ok, text):
        def done():
            if ok:
                self.progress_value.set(100)
            self.progress_text.set(text)
            if self.progress_win is not None and self.progress_win.winfo_exists():
                self.progress_win.after(1200, self.progress_win.destroy)
        self.root.after(0, done)

    def run_background(self, title, worker, success=None, error_title=None, show_success=True, on_success=None):
        if self.busy:
            messagebox.showinfo("Busy", "Another action is already running. Please wait.")
            return
        self.busy = True
        self.progress_start(title)
        def progress(percent, text):
            self.progress_update(percent, text)
        def task():
            try:
                result = worker(progress)
                def finish():
                    self.busy = False
                    if on_success:
                        on_success(result)
                    self.refresh_status_async()
                    self.progress_finish(True, "Done")
                    if show_success and success:
                        messagebox.showinfo(title, success)
                self.root.after(0, finish)
            except Exception as exc:
                def fail():
                    self.busy = False
                    self.refresh_status_async()
                    self.progress_finish(False, "Failed")
                    messagebox.showerror(error_title or f"{title} failed", str(exc))
                self.root.after(0, fail)
        threading.Thread(target=task, daemon=True).start()

    def restart_service_sync(self):
        subprocess.run(["systemctl", "--user", "daemon-reload"], text=True, capture_output=True)
        return run_command(["systemctl", "--user", "restart", "magic-mouse-gestures"], timeout=30)

    def update_profile_and_restart(self, values, progress):
        progress(15, "Reading current profile...")
        data = read_profile()
        data.update(values)
        progress(35, "Backing up profile...")
        backup_profile()
        progress(55, "Writing profile...")
        write_profile(data)
        progress(80, "Restarting gesture service...")
        result = self.restart_service_sync()
        if result.returncode != 0:
            raise RuntimeError(result.stderr or result.stdout or "Service restart failed")
        return data

    def apply_stable_defaults(self):
        self.apply_mapping(DEFAULT_MAPPING, "Stable defaults applied and the gesture service was restarted.")

    def apply_mapping(self, values, msg):
        self.run_background(
            "Apply gesture mapping",
            lambda progress: self.update_profile_and_restart(values, progress),
            success=msg,
            error_title="Gesture mapping failed",
        )

    def apply_sensitivity(self):
        preset = self.sensitivity_var.get()
        values = SENSITIVITY_PRESETS.get(preset)
        if not values:
            messagebox.showerror("Sensitivity", "Choose a valid preset.")
            return
        self.apply_mapping(values, f"Applied the '{preset}' preset and restarted the gesture service.")

    def restart_service(self):
        def worker(progress):
            progress(40, "Restarting gesture service...")
            result = self.restart_service_sync()
            if result.returncode != 0:
                raise RuntimeError(result.stderr or result.stdout or "Service restart failed")
            return result
        self.run_background("Restart service", worker, success="magic-mouse-gestures was restarted.", error_title="Service restart failed")

    def apply_scroll(self, mode, show_output):
        if not SCROLL_HELPER.exists():
            messagebox.showerror("Missing helper", f"Scroll helper not found:\n{SCROLL_HELPER}")
            return
        def worker(progress):
            progress(30, f"Running scroll helper: {mode}...")
            result = run_command([str(SCROLL_HELPER), mode], timeout=20)
            out = (result.stdout or "") + ("\n" + result.stderr if result.stderr else "")
            if result.returncode != 0:
                raise RuntimeError(out or "Scroll helper failed")
            return out
        def done(out):
            if show_output:
                show_output_window("Scroll direction", out or "No output")
        self.run_background("Scroll direction", worker, success=None if show_output else f"Applied {mode} scroll direction.", error_title="Scroll direction failed", on_success=done, show_success=not show_output)

    def repair_permissions(self):
        if not REPAIR.exists():
            messagebox.showerror("Missing script", f"Repair script not found:\n{REPAIR}")
            return
        password = simpledialog.askstring("Sudo password", "Enter sudo password for HID permission repair:", show="*", parent=self.root)
        if password is None:
            return
        def worker(progress):
            env = os.environ.copy()
            if password:
                env["MM_SUDO_PASSWORD"] = password
            progress(35, "Running HID permission repair...")
            result = subprocess.run([str(REPAIR)], text=True, capture_output=True, env=env, timeout=180)
            out = (result.stdout or "") + ("\n" + result.stderr if result.stderr else "")
            if result.returncode != 0:
                raise RuntimeError(out or "Repair failed")
            return out
        self.run_background("Repair HID permissions", worker, success="HID permission repair completed.", error_title="Repair failed", on_success=lambda out: show_output_window("Repair HID permissions", out or "No output"))

    def verify_setup(self):
        if not VERIFY.exists():
            messagebox.showerror("Missing script", f"Verify script not found:\n{VERIFY}")
            return
        def worker(progress):
            progress(35, "Running verify script...")
            result = run_command([str(VERIFY)], timeout=60)
            out = (result.stdout or "") + ("\n" + result.stderr if result.stderr else "")
            if result.returncode != 0:
                raise RuntimeError(out or "Verify failed")
            return out
        self.run_background("Verify setup", worker, error_title="Verify failed", show_success=False, on_success=lambda out: show_output_window("Verify report", out or "No output"))

    def test_workspace(self, direction):
        if not COSMIC_WS.exists():
            messagebox.showerror("Missing helper", f"Helper not found:\n{COSMIC_WS}")
            return
        def worker(progress):
            progress(50, f"Running cosmic-ws {direction}...")
            result = run_command([str(COSMIC_WS), direction], timeout=10)
            if result.returncode != 0:
                raise RuntimeError(result.stderr or result.stdout or "Workspace command failed")
            return result
        self.run_background(f"Workspace {direction}", worker, success=f"Ran cosmic-ws {direction}", error_title="Workspace test failed")

    def open_cli_panel(self):
        if not CLI_PANEL.exists():
            messagebox.showerror("Missing CLI panel", f"CLI panel not found:\n{CLI_PANEL}")
            return
        for candidate in (("x-terminal-emulator", "-e", str(CLI_PANEL)), ("cosmic-term", "-e", str(CLI_PANEL)), ("gnome-terminal", "--", str(CLI_PANEL)), ("xterm", "-e", str(CLI_PANEL))):
            if shutil.which(candidate[0]):
                subprocess.Popen(candidate)
                return
        messagebox.showinfo("CLI panel", f"Run manually:\n{CLI_PANEL}")

    def mapping_status(self, data):
        up = data.get("GESTURE_UP", "")
        down = data.get("GESTURE_DOWN", "")
        left = data.get("GESTURE_LEFT", "")
        right = data.get("GESTURE_RIGHT", "")
        ws = "workspace normal" if up.endswith(" up") and down.endswith(" down") else "workspace inverted" if up.endswith(" down") and down.endswith(" up") else "workspace custom"
        br = "browser normal" if "left" in left and "right" in right else "browser inverted" if "right" in left and "left" in right else "browser custom"
        return f"{ws}, {br}"

    def permission_status(self):
        result = run_command(["journalctl", "--user", "-u", "magic-mouse-gestures", "-n", "40", "-l", "--no-pager"], timeout=10)
        text = (result.stdout or "") + (result.stderr or "")
        if "cannot read it" in text:
            return "Needs repair"
        if "[hidraw] opened" in text or "profile=cosmic" in text:
            return "OK"
        return "Unknown"

    def scroll_status(self):
        if not SCROLL_HELPER.exists():
            return "helper missing"
        result = run_command([str(SCROLL_HELPER), "status"], timeout=10)
        text = (result.stdout or "") + (result.stderr or "")
        if "natural_scroll=true" in text or "natural-scroll=true" in text:
            return "Natural / Mac-style"
        if "natural_scroll=false" in text or "natural-scroll=false" in text:
            return "Traditional"
        return "Unset / unknown"

    def refresh_status_async(self):
        if getattr(self, "status_running", False):
            return
        self.status_running = True
        def worker():
            try:
                state = (run_command(["systemctl", "--user", "is-active", "magic-mouse-gestures"], timeout=10).stdout or "unknown").strip() or "unknown"
                data = read_profile()
                mapping = self.mapping_status(data)
                hid = self.permission_status()
                scroll = self.scroll_status()
                info = [f"Service: {state}", f"Mapping: {mapping}", f"HID: {hid}", f"Scroll: {scroll}", ""]
                if PROFILE.exists():
                    info.append("== Profile ==")
                    info.append(PROFILE.read_text())
                else:
                    info.append(f"Profile missing: {PROFILE}")
                def apply():
                    self.status_running = False
                    self.status_var.set(f"Service: {state} | Mapping: {mapping} | HID: {hid} | Scroll: {scroll}")
                    self.info_text.configure(state="normal")
                    self.info_text.delete("1.0", "end")
                    self.info_text.insert("1.0", "\n".join(info))
                    self.info_text.configure(state="disabled")
                self.root.after(0, apply)
            except Exception as exc:
                self.root.after(0, lambda: (setattr(self, "status_running", False), self.status_var.set(f"Status failed: {exc}")))
        threading.Thread(target=worker, daemon=True).start()


def main():
    root = tk.Tk()
    App(root)
    root.mainloop()


if __name__ == "__main__":
    main()
