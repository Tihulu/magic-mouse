    def _setup_step_frame(self, parent, num, title, description, command):
        frame = ttk.LabelFrame(parent, text=f"Step {num} — {title}", padding=10)
        frame.grid(row=num-1, column=0, sticky="ew", pady=6)
        frame.columnconfigure(1, weight=1)
        ttk.Label(frame, text="Status:").grid(row=0, column=0, sticky="w")
        ttk.Label(frame, textvariable=self.setup_status_vars[str(num)], foreground="#1b5").grid(row=0, column=1, sticky="w")
        ttk.Label(frame, text=description, wraplength=760, justify="left").grid(row=1, column=0, columnspan=2, sticky="w", pady=(4, 8))
        ttk.Button(frame, text=f"Run Step {num}", command=command).grid(row=0, column=2, rowspan=2, sticky="e", padx=(12, 0))
        return frame

    def _spinbox(self, parent, key, label, frm, to, row=0):
        ttk.Label(parent, text=label).grid(row=row, column=0, sticky="w", padx=(0, 8), pady=4)
        var = tk.StringVar()
        spin = ttk.Spinbox(parent, from_=frm, to=to, textvariable=var, width=12)
        spin.grid(row=row, column=1, sticky="w", pady=4)
        self.vars[key] = var

    def _entry(self, parent, key, label, width=20, row=0):
        ttk.Label(parent, text=label).grid(row=row, column=0, sticky="w", padx=(0, 8), pady=4)
        var = tk.StringVar()
        ent = ttk.Entry(parent, textvariable=var, width=width)
        ent.grid(row=row, column=1, sticky="ew", pady=4)
        parent.columnconfigure(1, weight=1)
        self.vars[key] = var

    def _check(self, parent, key, label, row=0, column=0):
        var = tk.IntVar(value=0)
        chk = ttk.Checkbutton(parent, text=label, variable=var)
        chk.grid(row=row, column=column, sticky="w", pady=4, padx=(0, 16))
        self.vars[key] = var

    def load_profile_to_ui(self):
        data = read_profile()
        for key, var in self.vars.items():
            value = data.get(key, DEFAULTS.get(key, ""))
            if isinstance(var, tk.IntVar):
                var.set(1 if str(value) == "1" else 0)
            else:
                var.set(str(value))
        self.sensitivity_var.set(self.detect_sensitivity_name(data))
        self.refresh_info_text()

    def load_defaults(self):
        for key, var in self.vars.items():
            value = DEFAULTS.get(key, "")
            if isinstance(var, tk.IntVar):
                var.set(1 if str(value) == "1" else 0)
            else:
                var.set(str(value))
        self.sensitivity_var.set("Default")

    def collect_values(self):
        values = {}
        for key, var in self.vars.items():
            if isinstance(var, tk.IntVar):
                values[key] = "1" if var.get() else "0"
            else:
                values[key] = var.get().strip()
        return values

    def validate_values(self, values):
        ints = ["MIN_TOUCHES", "MAX_FINGERS", "SWIPE_THRESHOLD_X", "SWIPE_THRESHOLD_Y", "SWIPE_COOLDOWN_MS"]
        for key in ints:
            if not values[key].isdigit():
                raise ValueError(f"{key} must be an integer")
        try:
            float(values["AXIS_LOCK_RATIO"])
        except ValueError:
            raise ValueError("AXIS_LOCK_RATIO must be a number")

    def apply_only(self):
        try:
            values = self.collect_values()
            self.validate_values(values)
            backup_profile()
            write_profile(values)
            self.refresh_status()
            messagebox.showinfo("Saved", f"Settings saved to:\n{PROFILE}")
        except Exception as exc:
            messagebox.showerror("Error", str(exc))

    def apply_and_restart(self):
        try:
            values = self.collect_values()
            self.validate_values(values)
            backup_profile()
            write_profile(values)
            self.restart_service(show_message=False)
            self.refresh_status()
            messagebox.showinfo("Applied", "Settings saved and the gesture service was restarted.")
        except Exception as exc:
            messagebox.showerror("Error", str(exc))

    def restart_service(self, show_message=True):
        subprocess.run(["systemctl", "--user", "daemon-reload"], text=True)
        result = run_command(["systemctl", "--user", "restart", "magic-mouse-gestures"])
        self.refresh_status()
        if show_message:
            if result.returncode == 0:
                messagebox.showinfo("Service", "magic-mouse-gestures was restarted.")
            else:
                messagebox.showerror("Service restart failed", result.stderr or result.stdout or "Unknown error")
        return result.returncode == 0

    def apply_mapping_values(self, values, message=None):
        current = read_profile()
        current.update(values)
        backup_profile()
        write_profile(current)
        self.load_profile_to_ui()
        self.restart_service(show_message=False)
        self.refresh_status()
        if message:
            messagebox.showinfo("Gesture mapping", message)

    def apply_stable_mapping(self):
        try:
            self.apply_mapping_values(DEFAULT_MAPPING, "Stable default mapping applied and the gesture service was restarted.")
        except Exception as exc:
            messagebox.showerror("Gesture mapping failed", str(exc))

    def normal_workspace_direction(self):
        try:
            self.apply_mapping_values(
                {**WORKSPACE_NORMAL, "MIN_TOUCHES": "2", "MAX_FINGERS": "5"},
                "Desktop/workspace direction set to normal and the gesture service was restarted.",
            )
        except Exception as exc:
            messagebox.showerror("Workspace direction failed", str(exc))

    def invert_workspace_direction(self):
        try:
            self.apply_mapping_values(
                {**WORKSPACE_INVERTED, "MIN_TOUCHES": "2", "MAX_FINGERS": "5"},
                "Desktop/workspace direction inverted and the gesture service was restarted.",
            )
        except Exception as exc:
            messagebox.showerror("Workspace direction failed", str(exc))

    def normal_browser_direction(self):
        try:
            self.apply_mapping_values(
                {**BROWSER_NORMAL, "MIN_TOUCHES": "2", "MAX_FINGERS": "5"},
                "Browser back/forward direction set to normal and the gesture service was restarted.",
            )
        except Exception as exc:
            messagebox.showerror("Browser direction failed", str(exc))

    def invert_browser_direction(self):
        try:
            self.apply_mapping_values(
                {**BROWSER_INVERTED, "MIN_TOUCHES": "2", "MAX_FINGERS": "5"},
                "Browser back/forward direction inverted and the gesture service was restarted.",
            )
        except Exception as exc:
            messagebox.showerror("Browser direction failed", str(exc))

    def restore_workspace_mapping(self):
        self.normal_workspace_direction()

    def disable_workspace_mapping(self):
        try:
            self.apply_mapping_values(
                {"GESTURE_UP": "true", "GESTURE_DOWN": "true"},
                "Workspace gestures disabled and the gesture service was restarted.",
            )
        except Exception as exc:
            messagebox.showerror("Gesture mapping failed", str(exc))

    def ensure_sudo_auth(self):
        cached = subprocess.run(["sudo", "-n", "-v"], text=True, capture_output=True)
        if cached.returncode == 0:
            return ""

        password = simpledialog.askstring(
            "Administrator password",
            "Repairing HID permissions needs administrator rights.\n\nEnter your sudo password. It is used once and is not saved.",
            show="*",
            parent=self.root,
        )
        if password is None:
            return None

        result = subprocess.run(["sudo", "-S", "-p", "", "-v"], input=password + "\n", text=True, capture_output=True)
        if result.returncode != 0:
            messagebox.showerror("Sudo authentication failed", result.stderr or "Wrong password or sudo is not available.")
            return None
        return password

    def repair_permissions(self):
        if not REPAIR.exists():
            messagebox.showerror("Missing script", f"Repair script not found:\n{REPAIR}")
            return False

        password = self.ensure_sudo_auth()
        if password is None:
            return False

        env = os.environ.copy()
        if password:
            env["MM_SUDO_PASSWORD"] = password

        result = subprocess.run([str(REPAIR)], text=True, capture_output=True, env=env)
        out = (result.stdout or "") + ("\n" + result.stderr if result.stderr else "")
        show_output_window("Repair HID permissions", out or "No output")
        self.refresh_status()
        if result.returncode != 0:
            messagebox.showerror("Repair failed", "HID permission repair did not complete. See the output window for details.")
        return result.returncode == 0

    def run_verify(self):
        if not VERIFY.exists():
            messagebox.showerror("Missing script", f"Verify script not found:\n{VERIFY}")
            return
        result = run_command([str(VERIFY)])
        out = (result.stdout or "") + ("\n" + result.stderr if result.stderr else "")
        show_output_window("Verify report", out or "No output")
        self.refresh_status()

    def open_status_report(self):
        self.run_verify()

    def apply_scroll_direction(self, mode, show_output=False):
        if not SCROLL_HELPER.exists():
            messagebox.showerror("Missing helper", f"Scroll helper not found:\n{SCROLL_HELPER}")
            return False
        result = run_command([str(SCROLL_HELPER), mode])
        out = (result.stdout or "") + ("\n" + result.stderr if result.stderr else "")
        self.refresh_status()
        if show_output or result.returncode != 0:
            show_output_window("Scroll direction", out or "No output")
        else:
            messagebox.showinfo(
                "Scroll direction",
                (out or f"Applied {mode} scroll direction.") + "\n\nIf values changed but real scroll did not, log out/in or restart COSMIC. If it still does not work, this is likely the known COSMIC mouse natural-scroll bug. Use Step 6 for desktop gesture direction.",
            )
        return result.returncode == 0

    def scroll_status(self):
        if not SCROLL_HELPER.exists():
            return "helper missing"
        result = run_command([str(SCROLL_HELPER), "status"])
        text = (result.stdout or "") + (result.stderr or "")
        if "input_mouse" in text and "natural_scroll=true" in text:
            return "Natural / Mac-style"
        if "input_mouse" in text and "natural_scroll=false" in text:
            return "Traditional"
        if "natural-scroll=true" in text:
            return "Natural / Mac-style"
        if "natural-scroll=false" in text:
            return "Traditional"
        return "Unset / unknown"

    def apply_sensitivity_preset(self):
        preset = self.sensitivity_var.get().strip()
        values = SENSITIVITY_PRESETS.get(preset)
        if not values:
            messagebox.showerror("Preset", "Choose a valid sensitivity preset.")
            return
        try:
            current = read_profile()
            current.update(values)
            backup_profile()
            write_profile(current)
            self.load_profile_to_ui()
            self.restart_service(show_message=False)
            self.refresh_status()
            messagebox.showinfo("Sensitivity", f"Applied the '{preset}' preset and restarted the gesture service.")
        except Exception as exc:
            messagebox.showerror("Sensitivity failed", str(exc))

    def apply_inversion_settings(self):
        try:
            current = read_profile()
            for key in ["INVERT_X_1F", "INVERT_Y_1F", "INVERT_X_2F", "INVERT_Y_2F"]:
                current[key] = "1" if self.vars[key].get() else "0"
            backup_profile()
            write_profile(current)
            self.load_profile_to_ui()
            self.restart_service(show_message=False)
            self.refresh_status()
            messagebox.showinfo("Inversion", "Per-finger inversion settings were applied and the service was restarted.")
        except Exception as exc:
            messagebox.showerror("Inversion failed", str(exc))


    def enable_one_finger_mode(self):
        if not messagebox.askyesno(
            "Enable experimental 1-finger mode?",
            "1-finger gesture mode sets MIN_TOUCHES=1 so the daemon can react to single-finger swipes.\n\n"
            "This may conflict with normal mouse movement or scrolling on Magic Mouse. Use Stable 2-Finger Mode if it feels noisy.\n\n"
            "Continue?",
            parent=self.root,
        ):
            return
        try:
            current = read_profile()
            current["MIN_TOUCHES"] = "1"
            current["MAX_FINGERS"] = "5"
            for key in ["INVERT_X_1F", "INVERT_Y_1F", "INVERT_X_2F", "INVERT_Y_2F"]:
                current[key] = "1" if self.vars[key].get() else "0"
            backup_profile()
            write_profile(current)
            self.load_profile_to_ui()
            self.restart_service(show_message=False)
            self.refresh_status()
            messagebox.showinfo("1-finger mode", "Experimental 1-finger gesture mode was enabled and the service was restarted.")
        except Exception as exc:
            messagebox.showerror("1-finger mode failed", str(exc))

    def enable_two_finger_mode(self):
        try:
            current = read_profile()
            current["MIN_TOUCHES"] = "2"
            current["MAX_FINGERS"] = "5"
            backup_profile()
            write_profile(current)
            self.load_profile_to_ui()
            self.restart_service(show_message=False)
            self.refresh_status()
            messagebox.showinfo("Stable 2-finger mode", "Stable 2-finger mode was enabled and the service was restarted.")
        except Exception as exc:
            messagebox.showerror("2-finger mode failed", str(exc))

    def test_workspace(self, direction):
        if not COSMIC_WS.exists():
            messagebox.showerror("Missing helper", f"Helper not found:\n{COSMIC_WS}")
            return
        result = run_command([str(COSMIC_WS), direction])
        if result.returncode == 0:
            messagebox.showinfo("Workspace test", f"Ran cosmic-ws {direction}")
        else:
            messagebox.showerror("Workspace test failed", result.stderr or result.stdout or "Unknown error")
        self.refresh_status()

    def open_cli_panel(self):
        if not CLI_PANEL.exists():
            messagebox.showerror("Missing CLI panel", f"CLI panel not found:\n{CLI_PANEL}")
            return
        for candidate in (("x-terminal-emulator", "-e", str(CLI_PANEL)), ("cosmic-term", "-e", str(CLI_PANEL)), ("gnome-terminal", "--", str(CLI_PANEL)), ("xterm", "-e", str(CLI_PANEL))):
            if shutil.which(candidate[0]):
                subprocess.Popen(candidate)
                return
        messagebox.showinfo("CLI panel", f"Run this command manually:\n{CLI_PANEL}")

    def detect_sensitivity_name(self, data):
        for name, preset in SENSITIVITY_PRESETS.items():
            if all(str(data.get(k, "")) == v for k, v in preset.items()):
                return name
        return "Custom"

    def mapping_status(self, data):
        browser_normal = all(str(data.get(k, "")) == v for k, v in BROWSER_NORMAL.items())
        browser_inverted = all(str(data.get(k, "")) == v for k, v in BROWSER_INVERTED.items())
        workspace_normal = all(str(data.get(k, "")) == v for k, v in WORKSPACE_NORMAL.items())
        workspace_inverted = all(str(data.get(k, "")) == v for k, v in WORKSPACE_INVERTED.items())

        if data.get("GESTURE_UP") == "true" and data.get("GESTURE_DOWN") == "true":
            workspace_text = "workspace disabled"
        elif workspace_inverted:
            workspace_text = "desktop inverted"
        elif workspace_normal:
            workspace_text = "desktop normal"
        else:
            workspace_text = "desktop custom"

        if browser_inverted:
            browser_text = "browser inverted"
        elif browser_normal:
            browser_text = "browser normal"
        else:
            browser_text = "browser custom"

        if browser_normal and workspace_normal and str(data.get("MIN_TOUCHES", "")) == "2":
            return "Stable default applied"
        return f"{workspace_text}, {browser_text}"

    def permission_status(self):
        log = run_command(["journalctl", "--user", "-u", "magic-mouse-gestures", "-n", "40", "-l", "--no-pager"])
        text = (log.stdout or "") + (log.stderr or "")
        if "cannot read it" in text:
            return "Needs repair"
        if "[hidraw] opened" in text or "profile=cosmic" in text:
            return "OK"
        return "Unknown"

    def _required_log(self, text):
        def update():
            if hasattr(self, "required_log_text") and self.required_log_text.winfo_exists():
                self.required_log_text.configure(state="normal")
                self.required_log_text.insert("end", text)
                self.required_log_text.see("end")
                self.required_log_text.configure(state="disabled")
        self.root.after(0, update)

    def _finish_required_steps(self, title, message):
        def update():
            self.required_steps_running = False
            self.refresh_status()
            if hasattr(self, "required_run_button"):
                self.required_run_button.configure(state="normal")
            messagebox.showinfo(title, message)
        self.root.after(0, update)

    def run_required_steps(self):
        if getattr(self, "required_steps_running", False):
            messagebox.showinfo("Setup is already running", "Required setup steps are already running.")
            return

        if not REPAIR.exists():
            messagebox.showerror("Missing script", f"Repair script not found:\n{REPAIR}")
            return

        password = self.ensure_sudo_auth()
        if password is None:
            return

        self.required_steps_running = True
        if hasattr(self, "required_run_button"):
            self.required_run_button.configure(state="disabled")

        win = tk.Toplevel(self.root)
        win.title("Required setup steps")
        win.geometry("900x560")
        ttk.Label(win, text="Running required setup steps...", font=("Sans", 12, "bold")).pack(anchor="w", padx=10, pady=(10, 4))
        ttk.Label(win, text="You can leave this window open. The main app should not freeze.").pack(anchor="w", padx=10, pady=(0, 8))
        self.required_log_text = ScrolledText(win, wrap="word", height=24)
        self.required_log_text.pack(fill="both", expand=True, padx=10, pady=(0, 10))
        self.required_log_text.insert("1.0", "Starting...\n")
        self.required_log_text.configure(state="disabled")

        thread = threading.Thread(target=self._run_required_steps_worker, args=(password,), daemon=True)
        thread.start()

    def _run_required_steps_worker(self, password):
        summary = []

        self._required_log("\n[1/3] Restarting gesture service...\n")
        restart = subprocess.run(
            ["systemctl", "--user", "restart", "magic-mouse-gestures"],
            text=True,
            capture_output=True,
        )
        self._required_log((restart.stdout or "") + (restart.stderr or ""))
        summary.append(f"Restart service: {'OK' if restart.returncode == 0 else 'Failed'}")

        self._required_log("\n[2/3] Repairing HID permissions...\n")
        env = os.environ.copy()
        if password:
            env["MM_SUDO_PASSWORD"] = password

        try:
            repair = subprocess.run(
                [str(REPAIR)],
                text=True,
                capture_output=True,
                env=env,
                timeout=180,
            )
            self._required_log((repair.stdout or "") + (repair.stderr or ""))
            summary.append(f"Repair HID permissions: {'OK' if repair.returncode == 0 else 'Failed'}")
        except subprocess.TimeoutExpired as exc:
            self._required_log("\nRepair timed out after 180 seconds.\n")
            if exc.stdout:
                self._required_log(exc.stdout)
            if exc.stderr:
                self._required_log(exc.stderr)
            summary.append("Repair HID permissions: Timed out")

        self._required_log("\n[3/3] Applying stable default gesture mapping...\n")
        try:
            current = read_profile()
            current.update(DEFAULT_MAPPING)
            backup_profile()
            write_profile(current)
            restart2 = subprocess.run(
                ["systemctl", "--user", "restart", "magic-mouse-gestures"],
                text=True,
                capture_output=True,
            )
            self._required_log((restart2.stdout or "") + (restart2.stderr or ""))
            summary.append("Apply stable default mapping: OK")
        except Exception as exc:
            self._required_log(f"Mapping failed: {exc}\n")
            summary.append(f"Apply stable default mapping: Failed ({exc})")

        self._required_log("\nDone.\n")
        self._finish_required_steps("Required setup steps finished", "\n".join(summary))

    def refresh_status(self):
        result = run_command(["systemctl", "--user", "is-active", "magic-mouse-gestures"])
        state = (result.stdout or "unknown").strip() or "unknown"
        data = read_profile()
        self.status_var.set(f"Service status: {state} | Mapping: {self.mapping_status(data)} | HID: {self.permission_status()} | Scroll: {self.scroll_status()}")

        self.setup_status_vars["1"].set("Ready" if PROFILE.exists() else "Profile not found")
        self.setup_status_vars["2"].set(f"Service is {state}")
        self.setup_status_vars["3"].set(self.permission_status())
        self.setup_status_vars["4"].set(self.detect_sensitivity_name(data))
        self.setup_status_vars["5"].set(self.scroll_status())
        self.setup_status_vars["6"].set(self.mapping_status(data))
        self.refresh_info_text()

    def refresh_info_text(self):
        info_lines = []
        service = run_command(["systemctl", "--user", "status", "magic-mouse-gestures", "-l", "--no-pager"])
        info_lines.append("== Service ==\n" + (service.stdout or service.stderr or "Unavailable"))
        if PROFILE.exists():
            info_lines.append("\n== Profile ==\n" + PROFILE.read_text())
        else:
            info_lines.append(f"\n== Profile ==\nMissing: {PROFILE}\n")
        state_file = Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / "magic-mouse-cosmic-ws.state"
        if state_file.exists():
            info_lines.append("\n== cosmic-ws state ==\n" + state_file.read_text())
        else:
            info_lines.append(f"\n== cosmic-ws state ==\nNo state file yet: {state_file}\n")
        self.info_text.configure(state="normal")
        self.info_text.delete("1.0", "end")
        self.info_text.insert("1.0", "\n".join(info_lines))
        self.info_text.configure(state="disabled")


def create_tk_root():
    original_display = os.environ.get("DISPLAY", "")
    candidates = []
    if original_display:
        candidates.append(original_display)
    for candidate in (":0", ":1"):
        if candidate not in candidates:
            candidates.append(candidate)

    if not candidates:
        candidates.append("")

    errors = []
    for display in candidates:
        if display:
            os.environ["DISPLAY"] = display
        elif "DISPLAY" in os.environ:
            del os.environ["DISPLAY"]

        # First try default Tk creation because it is the most compatible.
        # Then try className for better dock matching.
        for kwargs in ({}, {"className": APP_WM_CLASS}):
            try:
                root = tk.Tk(**kwargs)
                apply_app_window_identity(root)
                return root
            except tk.TclError as exc:
                errors.append(f"DISPLAY={display or '<unset>'} kwargs={kwargs}: {exc}")

    if original_display:
        os.environ["DISPLAY"] = original_display

    raise tk.TclError("\n".join(errors))


def launch_cli_fallback(message):
    print("Magic Mouse Control Panel GUI could not start.", file=sys.stderr)
    print(message, file=sys.stderr)
    print("", file=sys.stderr)
    print("Opening the terminal control panel instead...", file=sys.stderr)

    if CLI_PANEL.exists():
        subprocess.call([str(CLI_PANEL)])
    else:
        print(f"CLI panel not found: {CLI_PANEL}", file=sys.stderr)


def main():
    root = create_tk_root()
    style = ttk.Style()
    try:
        style.theme_use("clam")
    except Exception:
        pass
    App(root)
    root.mainloop()


if __name__ == "__main__":
    try:
        main()
    except tk.TclError as exc:
        launch_cli_fallback(str(exc))
        raise SystemExit(1)
    except Exception as exc:
        message = str(exc) or repr(exc)
        try:
            root = create_tk_root()
            root.withdraw()
            messagebox.showerror("Magic Mouse Control Panel", message)
        except Exception:
            print(message, file=sys.stderr)
            raise
