def read_profile():
    data = dict(DEFAULTS)
    if PROFILE.exists():
        for line in PROFILE.read_text().splitlines():
            stripped = line.strip()
            if not stripped or stripped.startswith("#") or "=" not in line:
                continue
            k, v = line.split("=", 1)
            data[k.strip()] = v.strip().strip('"')
    return data


def backup_profile():
    if PROFILE.exists():
        PROFILE.parent.mkdir(parents=True, exist_ok=True)
        ts = time.strftime("%Y%m%d-%H%M%S")
        shutil.copy2(PROFILE, PROFILE.with_name(PROFILE.name + f".bak.{ts}"))


def write_profile(values):
    PROFILE.parent.mkdir(parents=True, exist_ok=True)
    existing_lines = PROFILE.read_text().splitlines() if PROFILE.exists() else []
    out = []
    handled = set()
    quote_keys = {"GESTURE_LEFT", "GESTURE_RIGHT", "GESTURE_UP", "GESTURE_DOWN", "GESTURE_OVERVIEW", "PROFILE_NAME", "BACKEND", "HID_PATH"}
    for line in existing_lines:
        stripped = line.strip()
        if not stripped or stripped.startswith("#") or "=" not in line:
            out.append(line)
            continue
        k = line.split("=", 1)[0].strip()
        if k in values:
            v = values[k]
            out.append(f'{k}="{v}"' if k in quote_keys else f"{k}={v}")
            handled.add(k)
        else:
            out.append(line)
    for k, v in values.items():
        if k not in handled:
            out.append(f'{k}="{v}"' if k in quote_keys else f"{k}={v}")
    PROFILE.write_text("\n".join(out) + "\n")


def run_command(cmd):
    return subprocess.run(cmd, text=True, capture_output=True)


def show_output_window(title, text):
    win = tk.Toplevel()
    win.title(title)
    win.geometry("980x720")
    txt = ScrolledText(win, wrap="word")
    txt.pack(fill="both", expand=True)
    txt.insert("1.0", text)
    txt.configure(state="disabled")



class ScrollableFrame(ttk.Frame):
    def __init__(self, parent, padding=12):
        super().__init__(parent)
        self.canvas = tk.Canvas(self, borderwidth=0, highlightthickness=0)
        self.vbar = ttk.Scrollbar(self, orient="vertical", command=self.canvas.yview)
        self.canvas.configure(yscrollcommand=self.vbar.set)

        self.inner = ttk.Frame(self.canvas, padding=padding)
        self.window_id = self.canvas.create_window((0, 0), window=self.inner, anchor="nw")

        self.canvas.grid(row=0, column=0, sticky="nsew")
        self.vbar.grid(row=0, column=1, sticky="ns")
        self.rowconfigure(0, weight=1)
        self.columnconfigure(0, weight=1)

        self.inner.bind("<Configure>", self._on_inner_configure)
        self.canvas.bind("<Configure>", self._on_canvas_configure)
        self.canvas.bind("<Enter>", self._bind_mousewheel)
        self.canvas.bind("<Leave>", self._unbind_mousewheel)
        self.inner.bind("<Enter>", self._bind_mousewheel)
        self.inner.bind("<Leave>", self._unbind_mousewheel)

    def _on_inner_configure(self, _event=None):
        self.canvas.configure(scrollregion=self.canvas.bbox("all"))

    def _on_canvas_configure(self, event):
        self.canvas.itemconfigure(self.window_id, width=event.width)

    def _bind_mousewheel(self, _event=None):
        self.canvas.bind_all("<MouseWheel>", self._on_mousewheel)
        self.canvas.bind_all("<Button-4>", self._on_button4)
        self.canvas.bind_all("<Button-5>", self._on_button5)

    def _unbind_mousewheel(self, _event=None):
        self.canvas.unbind_all("<MouseWheel>")
        self.canvas.unbind_all("<Button-4>")
        self.canvas.unbind_all("<Button-5>")

    def _on_mousewheel(self, event):
        # Windows/macOS delta; works in many Tk builds on Linux too.
        step = int(-1 * (event.delta / 120)) if event.delta else 0
        if step:
            self.canvas.yview_scroll(step, "units")
        return "break"

    def _on_button4(self, _event):
        self.canvas.yview_scroll(-3, "units")
        return "break"

    def _on_button5(self, _event):
        self.canvas.yview_scroll(3, "units")
        return "break"



APP_WM_CLASS = "MagicMouseControlPanel"
APP_ICON_CANDIDATES = [
    HOME / ".local/share/icons/hicolor/256x256/apps/magic-mouse-control-panel.png",
    HOME / ".local/share/icons/hicolor/128x128/apps/magic-mouse-control-panel.png",
    HOME / ".local/share/icons/hicolor/64x64/apps/magic-mouse-control-panel.png",
]

def apply_app_window_identity(root):
    try:
        root.tk.call("tk", "appname", APP_WM_CLASS)
    except Exception:
        pass

    try:
        root.wm_class(APP_WM_CLASS, APP_WM_CLASS)
    except Exception:
        try:
            root.tk.call("wm", "class", root._w, APP_WM_CLASS)
        except Exception:
            pass

    try:
        root.wm_iconname("Magic Mouse Control Panel")
    except Exception:
        pass

    for icon_path in APP_ICON_CANDIDATES:
        if icon_path.exists():
            try:
                icon = tk.PhotoImage(file=str(icon_path))
                root.iconphoto(True, icon)
                root._magic_mouse_icon = icon
                break
            except Exception:
                continue

