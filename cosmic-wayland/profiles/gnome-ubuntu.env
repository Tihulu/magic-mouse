# GNOME/Ubuntu profile
# For Ubuntu, Pop!_OS 22.04, Fedora Workstation, Debian GNOME, and other GNOME-based desktops.

PROFILE_NAME="gnome-ubuntu"

# Browser navigation
GESTURE_LEFT="wtype -M alt -P left -p left -m alt"
GESTURE_RIGHT="wtype -M alt -P right -p right -m alt"

# Workspace navigation
# These defaults use the widely-supported Ctrl+Alt+Up/Down style.
# If your GNOME setup uses Super+Page_Up/Page_Down, edit these two lines:
# GESTURE_UP="wtype -M logo -P pageup -p pageup -m logo"
# GESTURE_DOWN="wtype -M logo -P pagedown -p pagedown -m logo"
GESTURE_UP="wtype -M ctrl -M alt -P up -p up -m alt -m ctrl"
GESTURE_DOWN="wtype -M ctrl -M alt -P down -p down -m alt -m ctrl"

# Reserved for a later tap/overview gesture.
GESTURE_OVERVIEW="wtype -M logo -s 120 -m logo"

# Gesture detection tuning
MIN_TOUCHES=2
SWIPE_THRESHOLD_X=360
SWIPE_THRESHOLD_Y=420
MAX_GESTURE_TIME_MS=900
SWIPE_COOLDOWN_MS=450
AXIS_LOCK_RATIO=1.15
INVERT_X=0
INVERT_Y=0
SINGLE_FINGER_INVERT_X=0
SINGLE_FINGER_INVERT_Y=0
TWO_FINGER_INVERT_X=0
TWO_FINGER_INVERT_Y=0

# Key command safety
COMMAND_TIMEOUT_SEC=2.0

# After a gesture fires, wait until all fingers lift before arming again.
WAIT_RELEASE_AFTER_FIRE=1
